<mxfile host="app.diagrams.net" agent="architecture" version="24.0.0">
  <diagram id="prod-azure" name="Producción (Azure)">
    <mxGraphModel dx="1422" dy="798" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2420" pageHeight="1680" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ARQUITECTURA DE PRODUCCIÓN — Detección de zonas rojas en un metaverso mediante Big Data en tiempo real&lt;br&gt;&lt;span style=&quot;font-size:12px;font-weight:normal&quot;&gt;Fiel al código: todo lo que aparece acá lo declara infra/ (Terraform), salvo el bloque rojo, que lo crea Databricks por su cuenta. Región: eastus2.&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2340" height="60" as="geometry" />
        </mxCell>

        <mxCell id="internet-lbl" value="INTERNET — el equipo y los usuarios" style="text;html=1;align=center;fontSize=12;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="NAVEGADOR — Three.js&lt;br&gt;&lt;br&gt;Renderiza el metaverso 3D.&lt;br&gt;El admin crea la sala, los usuarios&lt;br&gt;entran con el código, lanzan flotas&lt;br&gt;de avatares y ven las zonas rojas&lt;br&gt;pintarse y las rutas esquivarlas." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="250" height="220" as="geometry" />
        </mxCell>

        <mxCell id="sub" value="SUSCRIPCIÓN AZURE FOR STUDENTS ($100 / 12 meses, sin tarjeta) — región eastus2 — 6 resource groups provisionados con Terraform (infra/)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0078d4;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;spacingTop=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="140" width="2050" height="1230" as="geometry" />
        </mxCell>

        <mxCell id="rg-network" value="rg-metaverso-network&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;La red de la VM&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="230" width="330" height="260" as="geometry" />
        </mxCell>
        <mxCell id="vnet" value="vnet-metaverso-app&lt;br&gt;10.0.0.0/16" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="290" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="snet" value="snet-metaverso-app-public&lt;br&gt;10.0.1.0/24" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="355" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="nsg" value="nsg-metaverso-app&lt;br&gt;abre 22 (SSH) · 80 (web) · 8080 (WS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="420" width="280" height="55" as="geometry" />
        </mxCell>

        <mxCell id="rg-app" value="rg-metaverso-app&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;La VM que sirve el metaverso&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="520" width="330" height="400" as="geometry" />
        </mxCell>
        <mxCell id="vm" value="vm-metaverso-app&lt;br&gt;&lt;b&gt;Standard_E2s_v3&lt;/b&gt; (2 vCPU) · Ubuntu 22.04&lt;br&gt;&lt;br&gt;cloud-init clona el repo y levanta:&lt;br&gt;• nginx :80 → cliente Vite/Three.js&lt;br&gt;• bun :8080 → servidor autoritativo&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;(systemd: metaverse-server)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="385" y="580" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="pip" value="pip-metaverso-app&lt;br&gt;IP pública estática (Standard)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="720" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="nic" value="nic-metaverso-app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="785" width="280" height="45" as="geometry" />
        </mxCell>
        <mxCell id="disk" value="Disco de SO (Standard_LRS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="840" width="280" height="45" as="geometry" />
        </mxCell>

        <mxCell id="rg-streaming" value="rg-metaverso-streaming&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;El transporte de eventos&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="230" width="420" height="690" as="geometry" />
        </mxCell>
        <mxCell id="evhns" value="evhns-metaverso-&amp;lt;sufijo&amp;gt;&lt;br&gt;&lt;b&gt;Event Hubs — tier Standard, 1 TU&lt;/b&gt;&lt;br&gt;Kafka administrado · puerto 9093 · SASL_SSL&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Basic NO habla Kafka. Standard topea en 10 hubs.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="290" width="370" height="80" as="geometry" />
        </mxCell>
        <mxCell id="hub-pos" value="hub: avatar-positions&lt;br&gt;4 particiones · retención 1 día&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;ENTRADA: telemetría de cada avatar&lt;br&gt;consumer group: spark-detector&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="385" width="370" height="90" as="geometry" />
        </mxCell>
        <mxCell id="hub-sim" value="hub: sim-events&lt;br&gt;1 partición · retención 1 día&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;INTERNO: los 11 topics de simulación viajan&lt;br&gt;consolidados acá (el topic lógico va DENTRO&lt;br&gt;del mensaje) — no entran 13 hubs en Standard&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="490" width="370" height="100" as="geometry" />
        </mxCell>
        <mxCell id="hub-red" value="hub: red-points&lt;br&gt;1 partición · retención 1 día&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;SALIDA: zonas rojas detectadas&lt;br&gt;consumer group: metaverse-backend&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="605" width="370" height="90" as="geometry" />
        </mxCell>
        <mxCell id="authrule" value="app-access (regla de autorización del namespace)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;listen + send. Una sola connection string para la VM y para Spark.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="710" width="370" height="60" as="geometry" />
        </mxCell>
        <mxCell id="contract" value="CONTRATO DE DATOS (JSON)&lt;br&gt;&lt;br&gt;avatar-positions → { avatarId, x, y, speed, ts }&lt;br&gt;red-points → { cellX, cellY, centerX, centerY,&lt;br&gt;&amp;nbsp;&amp;nbsp;stationaryAvatars, windowStart, windowEnd }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="755" y="790" width="370" height="110" as="geometry" />
        </mxCell>

        <mxCell id="rg-analytics" value="rg-metaverso-analytics&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;El procesamiento&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1190" y="230" width="400" height="340" as="geometry" />
        </mxCell>
        <mxCell id="dbw" value="dbw-metaverso-detector&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Azure Databricks — SKU premium (Azure retiró Standard)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1215" y="290" width="350" height="60" as="geometry" />
        </mxCell>
        <mxCell id="job" value="job: red-point-detector&lt;br&gt;pipeline/red_point_detector.py&lt;br&gt;&lt;br&gt;&lt;b&gt;Job CONTINUO&lt;/b&gt; sobre job-cluster single-node&lt;br&gt;&lt;b&gt;Standard_D4s_v3&lt;/b&gt; (4 vCPU)&lt;br&gt;&lt;br&gt;Spark Structured Streaming:&lt;br&gt;1. Filtra avatares detenidos (speed ≈ 0)&lt;br&gt;2. Mapea (x,y) → celda 30×30, origen (-240,-195)&lt;br&gt;3. Ventana 10 s, se recalcula cada 5 s&lt;br&gt;4. ≥ 7 avatares quietos, permanencia ≥ 5 s → ZONA ROJA&lt;br&gt;&lt;br&gt;&lt;b&gt;Se crea PAUSADO&lt;/b&gt; — pausado = cluster apagado = $0/h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1215" y="360" width="350" height="190" as="geometry" />
        </mxCell>

        <mxCell id="rg-datalake" value="rg-metaverso-datalake&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;El archivo histórico&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1190" y="610" width="400" height="310" as="geometry" />
        </mxCell>
        <mxCell id="adls" value="stmetaverso&amp;lt;sufijo&amp;gt;&lt;br&gt;&lt;b&gt;ADLS Gen2&lt;/b&gt; (Storage Account, LRS, HNS)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;El nombre no puede ser más descriptivo: Azure topea los&lt;br&gt;storage accounts en 24 caracteres, sin guiones.&lt;br&gt;El propósito va en el tag.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1215" y="670" width="350" height="100" as="geometry" />
        </mxCell>
        <mxCell id="fs" value="filesystem: avatar-events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1215" y="785" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="archive-note" value="⚠ El archivado es OPT-IN (ENABLE_ARCHIVE=true). Apagado por defecto: sin credencial de storage en el cluster, el stream de archivo falla en su primer batch y se lleva puesto al de zonas rojas (awaitAnyTermination)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1215" y="835" width="350" height="70" as="geometry" />
        </mxCell>

        <mxCell id="rg-dbx" value="rg-metaverso-databricks-managed&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;⚠ LO CREA DATABRICKS, NO TERRAFORM&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fdf2f2;strokeColor=#b85450;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1630" y="230" width="520" height="690" as="geometry" />
        </mxCell>
        <mxCell id="dbx-warn" value="Databricks crea su propio resource group al crear el workspace. Terraform no lo conoce y &lt;b&gt;terraform destroy no lo borra&lt;/b&gt;: sale en verde y deja esto atrás. Como su nombre deriva del nuestro, un resto BLOQUEA la creación del próximo workspace.&lt;br&gt;&lt;br&gt;→ scripts/deploy-azure.sh lo borra en &lt;b&gt;down&lt;/b&gt; y verifica que no queden restos en el &lt;b&gt;preflight&lt;/b&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1655" y="290" width="470" height="115" as="geometry" />
        </mxCell>
        <mxCell id="nat" value="nat-gateway&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;La ÚNICA salida a internet&lt;br&gt;de los workers&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1655" y="420" width="225" height="75" as="geometry" />
        </mxCell>
        <mxCell id="natip" value="nat-gw-public-ip&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;IP de salida compartida (SNAT)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1895" y="420" width="230" height="75" as="geometry" />
        </mxCell>
        <mxCell id="nat-why" value="&lt;b&gt;¿Por qué hay un NAT gateway?&lt;/b&gt; Con &lt;i&gt;secure cluster connectivity&lt;/i&gt; (el default) los workers NO tienen IP pública y no aceptan nada entrante: son ELLOS los que abren un túnel SALIENTE al control plane de Databricks, y las órdenes bajan por ahí. Pero una VM sin IP pública no tiene forma de salir a internet — necesita SNAT. Ese es el NAT gateway.&lt;br&gt;&lt;br&gt;Sin esa salida el cluster ni se registra, y el job nunca arranca." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1655" y="505" width="470" height="130" as="geometry" />
        </mxCell>
        <mxCell id="workers" value="workers-vnet + workers-sg&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Red de los nodos del cluster (sin IP pública)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1655" y="645" width="470" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dbfs" value="dbstorage&amp;lt;aleatorio&amp;gt; — DBFS root (ZRS)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Storage interno OBLIGATORIO del workspace. No es opcional ni&lt;br&gt;configurable: por eso ves DOS storage accounts en la suscripción.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1655" y="710" width="470" height="65" as="geometry" />
        </mxCell>
        <mxCell id="ucc" value="unity-catalog-access-connector + dbmanagedidentity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1655" y="785" width="470" height="40" as="geometry" />
        </mxCell>
        <mxCell id="dbx-cost" value="💸 &lt;b&gt;El NAT gateway cobra ~$0.045/h mientras el workspace EXISTA&lt;/b&gt;, haya cluster o no. Se borra junto con el workspace. Lo que sobrevive al destroy (DBFS + connector) cuesta centavos, pero bloquea el redespliegue." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1655" y="835" width="470" height="70" as="geometry" />
        </mxCell>

        <mxCell id="rg-gov" value="rg-metaverso-governance — control de gasto (no sirve tráfico)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffdf5;strokeColor=#d6b656;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="960" width="1790" height="340" as="geometry" />
        </mxCell>
        <mxCell id="budget" value="budget-metaverso&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;(a nivel suscripción)&lt;/span&gt;&lt;br&gt;&lt;br&gt;$10 → email de aviso&lt;br&gt;$30 (75%) → email&lt;br&gt;pronóstico &amp;gt; $40 → email&lt;br&gt;&lt;b&gt;$40 → email + KILL-SWITCH&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="390" y="1020" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="ag" value="ag-metaverso-budget&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Action group&lt;/span&gt;&lt;br&gt;&lt;br&gt;Manda los emails&lt;br&gt;y llama al webhook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="1020" width="280" height="160" as="geometry" />
        </mxCell>
        <mxCell id="wh" value="wh-killswitch&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Webhook&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1020" width="220" height="160" as="geometry" />
        </mxCell>
        <mxCell id="aa" value="aa-metaverso-killswitch&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Automation Account (Basic)&lt;br&gt;runbook: Stop-BillableCompute&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Va en eastus2 obligatoriamente: es la ÚNICA región que comparten la política de la suscripción y la lista de Automation para cuentas Student.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1370" y="1020" width="340" height="160" as="geometry" />
        </mxCell>
        <mxCell id="effect" value="EFECTO&lt;br&gt;&lt;br&gt;• Desasigna la VM&lt;br&gt;&amp;nbsp;&amp;nbsp;(&quot;detenida&quot; sigue cobrando;&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;desasignada&lt;/b&gt; no)&lt;br&gt;• &lt;b&gt;Pausa&lt;/b&gt; los jobs&lt;br&gt;&amp;nbsp;&amp;nbsp;(cancelar no alcanza: el job es&lt;br&gt;&amp;nbsp;&amp;nbsp;continuo y se reinicia solo)&lt;br&gt;&lt;br&gt;No borra nada." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1760" y="1020" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="gov-note" value="⚠ Un budget de Azure NO corta el gasto: solo avisa. Por eso el 100% además dispara el runbook. Pero los datos de costo de Azure llegan con HORAS de retraso: cuando el budget ve los $40, el gasto real puede ser mayor. Esto es una red de seguridad, no un freno de mano. El freno de mano es &lt;b&gt;make detector-stop&lt;/b&gt; apenas termina la demo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="1200" width="1730" height="70" as="geometry" />
        </mxCell>

        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;html=1;startArrow=classic;endArrow=classic;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="browser" target="vm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f1-lbl" value="① HTTP :80 + WebSocket :8080&lt;br&gt;↓ posiciones de avatares&lt;br&gt;↑ zonas rojas y rutas recalculadas" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="55" y="440" width="250" height="50" as="geometry" />
        </mxCell>

        <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.25;entryX=0;entryY=0.5;" edge="1" parent="1" source="vm" target="hub-pos">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f2-lbl" value="② produce posiciones&lt;br&gt;(Kafka 9093, SASL_SSL)" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="672" y="520" width="140" height="35" as="geometry" />
        </mxCell>

        <mxCell id="f2b" style="edgeStyle=orthogonalEdgeStyle;html=1;startArrow=classic;endArrow=classic;strokeWidth=1;strokeColor=#82b366;dashed=1;exitX=1;exitY=0.6;entryX=0;entryY=0.5;" edge="1" parent="1" source="vm" target="hub-sim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="f3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d79b00;exitX=1;exitY=0.5;entryX=0;entryY=0.4;" edge="1" parent="1" source="hub-pos" target="job">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f3-lbl" value="③ Spark consume&lt;br&gt;(cg: spark-detector)" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1122" y="390" width="120" height="35" as="geometry" />
        </mxCell>

        <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d79b00;exitX=0;exitY=0.9;entryX=1;entryY=0.5;" edge="1" parent="1" source="job" target="hub-red">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f4-lbl" value="④ publica la zona roja" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1130" y="628" width="130" height="20" as="geometry" />
        </mxCell>

        <mxCell id="f5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#333333;exitX=0;exitY=0.5;entryX=1;entryY=0.85;" edge="1" parent="1" source="hub-red" target="vm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f5-lbl" value="⑤ la VM consume las zonas rojas (cg: metaverse-backend),&lt;br&gt;las empuja al navegador por ① y recalcula las rutas" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="480" y="930" width="380" height="30" as="geometry" />
        </mxCell>

        <mxCell id="f6" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=1;strokeColor=#6c8ebf;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="job" target="adls">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f6-lbl" value="⑥ archiva (opt-in)" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1332" y="578" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="f7" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#b85450;dashed=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;" edge="1" parent="1" source="job" target="nat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f7-lbl" value="⑦ los workers salen a internet SOLO por acá&lt;br&gt;(túnel saliente al control plane de Databricks)" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1592" y="345" width="290" height="30" as="geometry" />
        </mxCell>

        <mxCell id="f8" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d6b656;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="budget" target="ag">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f9" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d6b656;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="ag" target="wh">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d6b656;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="wh" target="aa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f11" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d6b656;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="aa" target="effect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="LEYENDA&lt;br&gt;&lt;br&gt;🟩 Verde — componentes propios (nuestro código)&lt;br&gt;🟦 Azul — servicios administrados de Azure (los declara Terraform)&lt;br&gt;⬛ Negro — hubs de Kafka (los canales de eventos)&lt;br&gt;🟧 Naranja — procesamiento analítico (Spark)&lt;br&gt;🟨 Amarillo — gobernanza y costos&lt;br&gt;🟥 Rojo — lo crea DATABRICKS por su cuenta: Terraform NO lo declara ni lo borra&lt;br&gt;&lt;br&gt;— línea punteada: flujo secundario u opcional" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="1400" width="640" height="230" as="geometry" />
        </mxCell>

        <mxCell id="cost" value="COSTO REAL&lt;br&gt;&lt;br&gt;• Event Hubs Standard (1 TU) — ~$11/mes FIJO, empieza a cobrar con el apply&lt;br&gt;• VM E2s_v3 prendida — ~$30/mes (desasignala: ./scripts/deploy-azure.sh vm-stop)&lt;br&gt;• Databricks, cluster — ~$0.50/h SOLO con el detector ON&lt;br&gt;• Databricks, &lt;b&gt;NAT gateway — ~$0.045/h mientras el workspace exista&lt;/b&gt;, haya cluster o no&lt;br&gt;• ADLS + DBFS + disco — centavos&lt;br&gt;• Budget, kill-switch, red — gratis&lt;br&gt;&lt;br&gt;&lt;b&gt;Lo que cobra en serio es el cluster: apagalo apenas termina la demo (make detector-stop).&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="1400" width="780" height="230" as="geometry" />
        </mxCell>

        <mxCell id="quota" value="LAS 3 RESTRICCIONES DE UNA SUSCRIPCIÓN STUDENT — fallan distinto, y confundirlas cuesta horas&lt;br&gt;&lt;br&gt;1. &lt;b&gt;Regiones permitidas&lt;/b&gt; → 403 RequestDisallowedByAzure (NO es un error de cuota)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;southcentralus · brazilsouth · &lt;b&gt;eastus2&lt;/b&gt; · mexicocentral · canadacentral&lt;br&gt;2. &lt;b&gt;6 vCPU totales&lt;/b&gt; por región&lt;br&gt;3. &lt;b&gt;4 vCPU por FAMILIA&lt;/b&gt; de VM — y el error aparece en el recurso equivocado&lt;br&gt;&lt;br&gt;Por eso la VM y el nodo de Spark están en familias DISTINTAS a propósito:&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;E2s_v3 (familia ESv3) = 2 vCPU&amp;nbsp;&amp;nbsp;+&amp;nbsp;&amp;nbsp;D4s_v3 (familia DSv3) = 4 vCPU&amp;nbsp;&amp;nbsp;→&amp;nbsp;&amp;nbsp;&lt;b&gt;6 / 6, justo al tope&lt;/b&gt;&lt;br&gt;En la misma familia se comerían los 4 vCPU entre sí y el cluster nunca arrancaría." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1500" y="1400" width="880" height="230" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="dev-qa-local" name="Dev/QA (Local — Distrobox)">
    <mxGraphModel dx="1422" dy="798" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1220" math="0" shadow="0">
      <root>
        <mxCell id="d0" />
        <mxCell id="d1" parent="d0" />

        <mxCell id="dtitle" value="ARQUITECTURA DEV/QA — el mismo sistema que producción, corriendo 100% local y a costo cero&lt;br&gt;&lt;span style=&quot;font-size:12px;font-weight:normal&quot;&gt;Un solo comando: &lt;b&gt;make dev&lt;/b&gt; levanta Kafka, detector, servidor y web (Ctrl-C los baja).&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="d1">
          <mxGeometry x="40" y="20" width="1820" height="60" as="geometry" />
        </mxCell>

        <mxCell id="host" value="HOST (bare metal) — se mantiene limpio: cero dependencias del proyecto instaladas en el sistema" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;verticalAlign=top;fontSize=13;fontStyle=1;spacingTop=8;dashed=1;" vertex="1" parent="d1">
          <mxGeometry x="40" y="110" width="1820" height="1050" as="geometry" />
        </mxCell>

        <mxCell id="box" value="DISTROBOX &quot;seminario&quot; — Ubuntu 24.04 · OpenJDK 17 · Python (venv) · bun · Azure CLI — comparte $HOME y red con el host (distrobox.ini)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=8;" vertex="1" parent="d1">
          <mxGeometry x="70" y="170" width="1760" height="960" as="geometry" />
        </mxCell>

        <mxCell id="dbrowser" value="NAVEGADOR&lt;br&gt;localhost:5173 (Vite)&lt;br&gt;&lt;br&gt;El MISMO cliente Three.js&lt;br&gt;que corre en producción" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="d1">
          <mxGeometry x="110" y="240" width="290" height="120" as="geometry" />
        </mxCell>

        <mxCell id="dserver" value="SERVIDOR AUTORITATIVO&lt;br&gt;metaverse/server/index.js [bun :8080]&lt;br&gt;&lt;br&gt;• WebSocket con el navegador&lt;br&gt;• Simula el tráfico y mueve los avatares&lt;br&gt;• Produce avatar-positions y sim-events&lt;br&gt;• Consume red-points → pinta la zona&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;y manda a recalcular las rutas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="d1">
          <mxGeometry x="110" y="430" width="290" height="170" as="geometry" />
        </mxCell>

        <mxCell id="dkafka" value="APACHE KAFKA 3.9.1 — nativo, SIN Docker&lt;br&gt;KRaft single-node (sin ZooKeeper)&lt;br&gt;localhost:9092 · PLAINTEXT (sin autenticación)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;instalado en ~/.local · datos en kraft-data/&lt;br&gt;operado por scripts/kafka-local.sh&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="d1">
          <mxGeometry x="530" y="240" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="dtopic1" value="topic: avatar-positions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="d1">
          <mxGeometry x="530" y="390" width="380" height="45" as="geometry" />
        </mxCell>
        <mxCell id="dtopic2" value="topic: sim-events&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;(los 11 topics internos, consolidados en uno)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="d1">
          <mxGeometry x="530" y="450" width="380" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dtopic3" value="topic: red-points" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="d1">
          <mxGeometry x="530" y="520" width="380" height="45" as="geometry" />
        </mxCell>
        <mxCell id="dparity-topics" value="Los MISMOS 3 topics que en Azure. En prod son &quot;hubs&quot; de Event Hubs; el código no nota la diferencia." style="text;html=1;align=center;fontSize=10;whiteSpace=wrap;" vertex="1" parent="d1">
          <mxGeometry x="530" y="575" width="380" height="30" as="geometry" />
        </mxCell>

        <mxCell id="ddetector" value="DETECTOR DE ZONAS ROJAS&lt;br&gt;pipeline/red_point_detector.py&lt;br&gt;PySpark — Structured Streaming local&lt;br&gt;&lt;br&gt;1. Filtra avatares detenidos (speed ≈ 0)&lt;br&gt;2. Celda de 30×30, origen (-240,-195)&lt;br&gt;3. Ventana 10 s, se recalcula cada 5 s&lt;br&gt;4. ≥ 7 quietos, permanencia ≥ 5 s → ZONA ROJA&lt;br&gt;&lt;br&gt;&lt;b&gt;Es EL MISMO archivo que corre en Databricks.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="d1">
          <mxGeometry x="1040" y="240" width="380" height="190" as="geometry" />
        </mxCell>

        <mxCell id="dcheckpoint" value="checkpoints/ — la memoria del stream&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Guarda los offsets leídos y el estado de las ventanas: permite reanudar sin perder ni duplicar.&lt;br&gt;&lt;br&gt;&lt;b&gt;make clean&lt;/b&gt; al cambiar la ventana o la agregación. Un checkpoint viejo ENVENENA el stream: las&lt;br&gt;zonas rojas dejan de aparecer y no hay ni un error a la vista. (Nos pasó — está en la bitácora.)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="d1">
          <mxGeometry x="1040" y="460" width="380" height="145" as="geometry" />
        </mxCell>

        <mxCell id="dparity" value="PARIDAD DEV ↔ PROD — la razón de ser de este diseño&lt;br&gt;&lt;br&gt;El detector es EL MISMO archivo que corre en Databricks. El servidor es EL MISMO que corre en la VM.&lt;br&gt;Cambiar de entorno NO cambia una línea de código: solo se cambia el .env.&lt;br&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;cp env/env.dev.example .env&amp;nbsp;&amp;nbsp;→&amp;nbsp;&amp;nbsp;KAFKA_BOOTSTRAP=localhost:9092&amp;nbsp;&amp;nbsp;(PLAINTEXT, sin auth)&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;cp env/env.prod.example .env&amp;nbsp;&amp;nbsp;→&amp;nbsp;&amp;nbsp;KAFKA_BOOTSTRAP=&amp;lt;namespace&amp;gt;.servicebus.windows.net:9093&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;+ EVENTHUBS_CONNECTION_STRING → el mismo código pasa a SASL_SSL&lt;br&gt;&lt;br&gt;La CALIBRACIÓN también tiene una sola fuente de verdad: &lt;b&gt;env/env.prod.example&lt;/b&gt;, que lee deploy-azure.sh para&lt;br&gt;cablear el job de Databricks. Por eso el detector de Azure no puede quedar desincronizado del overlay del metaverso." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="d1">
          <mxGeometry x="110" y="660" width="1310" height="230" as="geometry" />
        </mxCell>

        <mxCell id="dmake" value="INTERFAZ OPERATIVA — Makefile (make help)&lt;br&gt;&lt;br&gt;&lt;b&gt;LOCAL&lt;/b&gt;&lt;br&gt;make dev — todo el loop de una&lt;br&gt;make test — tests del detector (sin Kafka)&lt;br&gt;make metaverse-test — tests JS&lt;br&gt;make consume TOPIC=x — mirar un topic&lt;br&gt;make clean — borra los checkpoints&lt;br&gt;&lt;br&gt;&lt;b&gt;AZURE&lt;/b&gt;&lt;br&gt;make deploy — infra + app + job (pausado)&lt;br&gt;make detector-start — detector ON (cobra)&lt;br&gt;make detector-stop — detector OFF ($0/h)&lt;br&gt;make deploy-status — IP, VM, detector&lt;br&gt;make deploy-down — destruye todo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="d1">
          <mxGeometry x="1460" y="240" width="340" height="365" as="geometry" />
        </mxCell>

        <mxCell id="dtests" value="VALIDACIÓN&lt;br&gt;&lt;br&gt;&lt;b&gt;make test&lt;/b&gt;&lt;br&gt;• tests/test_detection_logic.py&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;la lógica de detección en batch, sin Kafka&lt;br&gt;• tests/test_position_parsing.py&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;la costura JS → Spark (el contrato de datos)&lt;br&gt;&lt;br&gt;&lt;b&gt;make metaverse-test&lt;/b&gt;&lt;br&gt;• metaverse/tests/integration.test.js" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="d1">
          <mxGeometry x="1460" y="660" width="340" height="230" as="geometry" />
        </mxCell>

        <mxCell id="de1" style="edgeStyle=orthogonalEdgeStyle;html=1;startArrow=classic;endArrow=classic;strokeWidth=2;strokeColor=#82b366;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="d1" source="dbrowser" target="dserver">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="de1l" value="WebSocket :8080" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="d1">
          <mxGeometry x="195" y="385" width="120" height="20" as="geometry" />
        </mxCell>

        <mxCell id="de2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.2;entryX=0;entryY=0.5;" edge="1" parent="d1" source="dserver" target="dtopic1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="de3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d79b00;exitX=1;exitY=0.3;entryX=0;entryY=0.4;" edge="1" parent="d1" source="dtopic1" target="ddetector">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="de4" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d79b00;exitX=0;exitY=0.9;entryX=1;entryY=0.5;" edge="1" parent="d1" source="ddetector" target="dtopic3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="de5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeWidth=2;strokeColor=#333333;exitX=0;exitY=0.5;entryX=1;entryY=0.8;" edge="1" parent="d1" source="dtopic3" target="dserver">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
