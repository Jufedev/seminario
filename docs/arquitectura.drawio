<mxfile host="app.diagrams.net" agent="architecture" version="24.0.0">
  <diagram id="prod-azure" name="Producción (Azure)">
    <mxGraphModel dx="1422" dy="798" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2420" pageHeight="1950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ARQUITECTURA DE PRODUCCIÓN — Detección de zonas rojas en un metaverso mediante Big Data en tiempo real&lt;br&gt;&lt;span style=&quot;font-size:12px;font-weight:normal&quot;&gt;Fiel al código: todo lo que aparece acá lo declara infra/ (Terraform). Seis resource groups, UNA sola etapa de apply, ningún recurso huérfano. Región: eastus2.&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2340" height="60" as="geometry" />
        </mxCell>

        <mxCell id="internet-lbl" value="INTERNET — el equipo y los usuarios" style="text;html=1;align=center;fontSize=12;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="NAVEGADOR — Three.js&lt;br&gt;&lt;br&gt;Renderiza el metaverso 3D.&lt;br&gt;El admin crea la sala, los usuarios&lt;br&gt;entran con el código, lanzan flotas&lt;br&gt;de avatares y ven las zonas rojas&lt;br&gt;pintarse y las rutas esquivarlas." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="250" height="220" as="geometry" />
        </mxCell>

        <mxCell id="sub" value="SUSCRIPCIÓN AZURE FOR STUDENTS ($100 / 12 meses, sin tarjeta) — región eastus2 — 6 resource groups, uno por ROL del pipeline, todos provisionados con Terraform (infra/)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0078d4;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;spacingTop=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="140" width="2050" height="1230" as="geometry" />
        </mxCell>

        <mxCell id="rg-network" value="rg-metaverso-network&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;La red de la VM&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="230" width="330" height="260" as="geometry" />
        </mxCell>
        <mxCell id="vnet" value="vnet-metaverso-app&lt;br&gt;10.0.0.0/16" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="290" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="snet" value="snet-metaverso-app-public&lt;br&gt;10.0.1.0/24" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="355" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="nsg" value="nsg-metaverso-app&lt;br&gt;abre 22 (SSH) · 80 (web) · 8080 (WS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="420" width="280" height="55" as="geometry" />
        </mxCell>

        <mxCell id="rg-app" value="rg-metaverso-app&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;La VM que sirve el metaverso — la ÚNICA VM del despliegue&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="520" width="330" height="400" as="geometry" />
        </mxCell>
        <mxCell id="vm" value="vm-metaverso-app&lt;br&gt;&lt;b&gt;Standard_E2s_v3&lt;/b&gt; (2 vCPU) · Ubuntu 22.04&lt;br&gt;&lt;br&gt;cloud-init clona el repo y levanta:&lt;br&gt;• nginx :80 → cliente Vite/Three.js&lt;br&gt;• bun :8080 → servidor autoritativo&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;(systemd: metaverse-server)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="385" y="580" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="pip" value="pip-metaverso-app&lt;br&gt;IP pública estática (Standard)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="720" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="nic" value="nic-metaverso-app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="785" width="280" height="45" as="geometry" />
        </mxCell>
        <mxCell id="disk" value="Disco de SO (Standard_LRS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="385" y="840" width="280" height="45" as="geometry" />
        </mxCell>

        <mxCell id="rg-streaming" value="rg-metaverso-streaming&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;El transporte de eventos&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="230" width="400" height="690" as="geometry" />
        </mxCell>
        <mxCell id="evhns" value="evhns-metaverso-&amp;lt;sufijo&amp;gt;&lt;br&gt;&lt;b&gt;Event Hubs — tier Standard, 1 TU&lt;/b&gt;&lt;br&gt;Kafka administrado · puerto 9093 · SASL_SSL&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Basic NO habla Kafka. Standard topea en 10 hubs.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="290" width="350" height="80" as="geometry" />
        </mxCell>
        <mxCell id="hub-pos" value="hub: avatar-positions&lt;br&gt;4 particiones · &lt;b&gt;retención 7 días&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;ENTRADA: telemetría de cada avatar&lt;br&gt;&lt;b&gt;Sin consumer group declarado&lt;/b&gt;: el source de Kafka de&lt;br&gt;Spark genera el suyo (spark-kafka-source-&amp;lt;uuid&amp;gt;) y&lt;br&gt;guarda los offsets en SU checkpoint, no en el broker.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="385" width="350" height="105" as="geometry" />
        </mxCell>
        <mxCell id="hub-sim" value="hub: sim-events&lt;br&gt;1 partición · retención 7 días&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;INTERNO: los 11 topics de simulación viajan&lt;br&gt;consolidados acá (el topic lógico va DENTRO&lt;br&gt;del mensaje) — no entran 13 hubs en Standard&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="505" width="350" height="100" as="geometry" />
        </mxCell>
        <mxCell id="hub-red" value="hub: red-points&lt;br&gt;1 partición · retención 7 días&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;SALIDA: zonas rojas detectadas&lt;br&gt;El backend consume con un consumer group EFÍMERO por&lt;br&gt;proceso (ecci-redpoints-&amp;lt;pid&amp;gt;-&amp;lt;ts&amp;gt;): las zonas rojas son estado&lt;br&gt;VIVO con TTL, y un offset commiteado las resucitaría al reiniciar.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="620" width="350" height="110" as="geometry" />
        </mxCell>
        <mxCell id="authrule" value="app-access (regla de autorización del namespace)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;listen + send. Una sola connection string para la VM y para el detector.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="745" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="contract" value="CONTRATO DE DATOS (JSON)&lt;br&gt;&lt;br&gt;avatar-positions → { avatarId, x, y, speed, ts }&lt;br&gt;red-points → { cellX, cellY, centerX, centerY,&lt;br&gt;&amp;nbsp;&amp;nbsp;stationaryAvatars, windowStart, windowEnd }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="755" y="810" width="350" height="95" as="geometry" />
        </mxCell>

        <mxCell id="rg-analytics" value="rg-metaverso-analytics&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;El procesamiento: el detector, containerizado&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="230" width="500" height="690" as="geometry" />
        </mxCell>
        <mxCell id="acr" value="cr&amp;lt;metaverso&amp;gt;&amp;lt;sufijo&amp;gt;&lt;br&gt;&lt;b&gt;Azure Container Registry (Basic, ~$5/mes)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;La imagen se construye con &lt;b&gt;az acr build&lt;/b&gt;: DENTRO de Azure. No es una&lt;br&gt;preferencia — en la caja de desarrollo no hay Docker ni Podman.&lt;br&gt;El tag es el HASH del contenido (Dockerfile + detector + entrypoint):&lt;br&gt;tocar el detector = tag nuevo = revisión nueva. Sin cambios, no rebuildea.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1265" y="290" width="450" height="110" as="geometry" />
        </mxCell>
        <mxCell id="mi" value="id-metaverso-detector&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Managed identity (user-assigned) con rol &lt;b&gt;AcrPull&lt;/b&gt; sobre el registro.&lt;br&gt;El contenedor baja su imagen con ella: no hay contraseña de registro&lt;br&gt;en ningún lado — ni en el estado de Terraform, ni en una shell.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1265" y="410" width="450" height="75" as="geometry" />
        </mxCell>
        <mxCell id="cae" value="cae-metaverso — Container Apps Environment&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;El entorno serverless donde vive el contenedor (plan Consumption)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1265" y="495" width="450" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ca" value="ca-metaverso-detector&lt;br&gt;&lt;b&gt;Container App — sin ingress&lt;/b&gt; (es un worker de fondo)&lt;br&gt;&lt;b&gt;2 vCPU / 4 GiB&lt;/b&gt; · max_replicas = 1&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;max = 1 porque la query es stateful y single-node: dos réplicas serían&lt;br&gt;dos detectores emitiendo las mismas zonas rojas.&lt;/span&gt;&lt;br&gt;&lt;br&gt;Corre el MISMO &lt;b&gt;pipeline/red_point_detector.py&lt;/b&gt; — Spark Structured Streaming:&lt;br&gt;1. Filtra avatares detenidos (speed ≈ 0)&lt;br&gt;2. Mapea (x,y) → celda 30×30, origen (-240,-195)&lt;br&gt;3. Ventana 10 s, se recalcula cada 5 s&lt;br&gt;4. ≥ 7 avatares quietos, permanencia ≥ 5 s → ZONA ROJA&lt;br&gt;&lt;br&gt;&lt;b&gt;min_replicas ES EL INTERRUPTOR DE LA DEMO:&lt;/b&gt;&lt;br&gt;&lt;b&gt;0&lt;/b&gt; = no hay contenedor = &lt;b&gt;$0/hora&lt;/b&gt;&amp;nbsp;&amp;nbsp;·&amp;nbsp;&amp;nbsp;&lt;b&gt;1&lt;/b&gt; = detector ON, arriba en &lt;b&gt;SEGUNDOS&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;(make detector-start / make detector-stop lo mueven vía Terraform)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1265" y="555" width="450" height="250" as="geometry" />
        </mxCell>
        <mxCell id="loga" value="log-metaverso-detector — Log Analytics&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;El stdout del contenedor es la ÚNICA ventana a la consulta de streaming.&lt;br&gt;El entrypoint imprime un banner al arrancar: si aparece dos veces, el contenedor se reinició.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1265" y="820" width="450" height="70" as="geometry" />
        </mxCell>

        <mxCell id="rg-datalake" value="rg-metaverso-datalake&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal&quot;&gt;El estado del detector y el archivo histórico&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f6fc;strokeColor=#0078d4;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1780" y="230" width="570" height="690" as="geometry" />
        </mxCell>
        <mxCell id="adls" value="stmetaverso&amp;lt;sufijo&amp;gt;&lt;br&gt;&lt;b&gt;ADLS Gen2&lt;/b&gt; (Storage Account, LRS, &lt;b&gt;is_hns_enabled = true&lt;/b&gt;)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;El nombre no puede ser más descriptivo: Azure topea los storage accounts&lt;br&gt;en 24 caracteres, sin guiones. El propósito va en el tag.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1805" y="290" width="520" height="85" as="geometry" />
        </mxCell>
        <mxCell id="fs" value="filesystem: avatar-events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1805" y="385" width="520" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ckpt" value="&lt;b&gt;checkpoints/red-point-detector&lt;/b&gt; — SIEMPRE&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;El checkpoint de Spark: los offsets de Event Hubs y el estado de las ventanas.&lt;br&gt;NO es opt-in. Vive acá y no en el contenedor a propósito: si Container Apps&lt;br&gt;reinicia una réplica (OOM, evicción, mantenimiento), retoma desde los offsets&lt;br&gt;commiteados en vez de saltar a &quot;latest&quot; y abrir un agujero de detección mudo.&lt;br&gt;&lt;b&gt;Cambiar la ventana en prod es una MIGRACIÓN, no un &lt;i&gt;make clean&lt;/i&gt;.&lt;/b&gt;&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1805" y="435" width="520" height="110" as="geometry" />
        </mxCell>
        <mxCell id="positions" value="&lt;b&gt;positions/&lt;/b&gt; — OPT-IN (ENABLE_ARCHIVE=true)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;El archivo histórico crudo de posiciones, en Parquet: la pata &quot;Big Data&quot; del trabajo.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1805" y="555" width="520" height="60" as="geometry" />
        </mxCell>
        <mxCell id="archive-note" value="⚠ El archivo está APAGADO por defecto, y no por timidez: el stream del archivo comparte &lt;b&gt;awaitAnyTermination()&lt;/b&gt; con el de zonas rojas, así que si falla en su primer batch se lleva puesto al DETECTOR. Encendelo sabiendo eso. (El checkpoint NO depende de este flag.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1805" y="625" width="520" height="70" as="geometry" />
        </mxCell>
        <mxCell id="hns-why" value="&lt;b&gt;¿Por qué is_hns_enabled = true?&lt;/b&gt; Un namespace jerárquico de verdad da &lt;b&gt;RENAME ATÓMICO&lt;/b&gt;, y eso no es un lujo: es la primitiva sobre la que está construido el protocolo de commit del checkpoint de Spark. El blob plano no puede darla — ahí el &quot;rename&quot; es copiar y borrar, y un fallo a mitad de camino deja el checkpoint corrupto.&lt;br&gt;&lt;br&gt;La imagen del detector trae el driver &lt;b&gt;hadoop-azure (ABFS)&lt;/b&gt;, que PySpark NO incluye: sin él, &lt;i&gt;abfss://&lt;/i&gt; no existe. En Databricks venía con el runtime y parecía gratis." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1805" y="705" width="520" height="125" as="geometry" />
        </mxCell>
        <mxCell id="secrets-note" value="🔑 La connection string de Event Hubs y la clave de ADLS son &lt;b&gt;secrets de Container Apps&lt;/b&gt;, no env vars: un env var lo lee cualquiera con permiso de READER en el portal. El entrypoint vuelca la clave en spark-defaults.conf antes de arrancar el JVM, así que nunca pasa por una línea de comandos ni aparece en &lt;i&gt;ps&lt;/i&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1805" y="840" width="520" height="65" as="geometry" />
        </mxCell>

        <mxCell id="rg-gov" value="rg-metaverso-governance — control de gasto (no sirve tráfico)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffdf5;strokeColor=#d6b656;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="960" width="1990" height="370" as="geometry" />
        </mxCell>
        <mxCell id="budget" value="budget-metaverso&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;(a nivel suscripción)&lt;/span&gt;&lt;br&gt;&lt;br&gt;$10 → email de aviso&lt;br&gt;$30 (75%) → email&lt;br&gt;pronóstico &amp;gt; $40 → email&lt;br&gt;&lt;b&gt;$40 → email + KILL-SWITCH&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="390" y="1020" width="330" height="190" as="geometry" />
        </mxCell>
        <mxCell id="ag" value="ag-metaverso-budget&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Action group&lt;/span&gt;&lt;br&gt;&lt;br&gt;Manda los emails&lt;br&gt;y llama al webhook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="1020" width="270" height="190" as="geometry" />
        </mxCell>
        <mxCell id="wh" value="wh-killswitch&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Webhook&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1090" y="1020" width="200" height="190" as="geometry" />
        </mxCell>
        <mxCell id="aa" value="aa-metaverso-killswitch&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Automation Account (Basic)&lt;br&gt;runbook: Stop-BillableCompute&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Va en eastus2 obligatoriamente: es la ÚNICA región que comparten la política de la suscripción y la lista de Automation para cuentas Student.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1340" y="1020" width="340" height="190" as="geometry" />
        </mxCell>
        <mxCell id="effect" value="EFECTO — apaga lo que cobra por HORA&lt;br&gt;&lt;br&gt;• &lt;b&gt;Desasigna la VM&lt;/b&gt; (&quot;detenida&quot; sigue cobrando; desasignada no)&lt;br&gt;• &lt;b&gt;Escala ca-metaverso-detector a min_replicas = 0&lt;/b&gt; — el mismo interruptor que usa &lt;i&gt;make detector-stop&lt;/i&gt;&lt;br&gt;&lt;br&gt;No borra nada.&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Lo hace con un &lt;b&gt;rol custom de 4 acciones&lt;/b&gt;, no con Contributor: virtualMachines read + deallocate, containerApps read + write. La identidad la despierta un WEBHOOK alcanzable por URL — con Contributor en rg-analytics podría borrar el registro, reescribir la imagen del detector o leer sus secrets. Un guardián de costos no puede tener permiso para romper lo que está salvando.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1730" y="1020" width="590" height="190" as="geometry" />
        </mxCell>
        <mxCell id="gov-note" value="⚠ Un budget de Azure NO corta el gasto: solo avisa. Por eso el 100% además dispara el runbook. Pero los datos de costo de Azure llegan con HORAS de retraso: cuando el budget ve los $40, el gasto real puede ser mayor. Esto es una red de seguridad, no un freno de mano. El freno de mano es &lt;b&gt;make detector-stop&lt;/b&gt; apenas termina la demo — y, si no hay más demos por hoy, &lt;b&gt;make deploy-down&lt;/b&gt;.&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;El kill-switch escala el contenedor a 0 por AFUERA de Terraform, así que un &lt;i&gt;apply&lt;/i&gt; posterior lo revertiría sin decir nada. Por eso deploy-azure.sh corre un &lt;b&gt;guard&lt;/b&gt; antes de cada apply: si Azure tiene 0 réplicas y el tfvars pide &lt;i&gt;true&lt;/i&gt;, aborta. Volver a encender es una decisión de una persona: &lt;i&gt;make detector-start&lt;/i&gt;.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="390" y="1225" width="1930" height="90" as="geometry" />
        </mxCell>

        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;html=1;startArrow=classic;endArrow=classic;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="browser" target="vm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f1-lbl" value="① HTTP :80 + WebSocket :8080&lt;br&gt;↓ posiciones de avatares&lt;br&gt;↑ zonas rojas y rutas recalculadas" style="text;html=1;align=center;fontSize=10;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
