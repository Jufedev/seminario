# ─────────────────────────────────────────────────────────────────────────
# PRODUCTION profile — Azure. Kafka is the Event Hubs Kafka endpoint,
# Spark runs on Databricks. Provisioned by Terraform (infra/).
#
# Usage:  cp env/env.prod.example .env  and fill from your `terraform output`.
# NEVER commit real secrets — .env is gitignored.
#
# Same variable names as env.dev.example on purpose: the detector and the
# metaverse switch endpoints by environment, not by code change (dev↔prod parity).
# ─────────────────────────────────────────────────────────────────────────

# Event Hubs Kafka endpoint (namespace host, port 9093).
KAFKA_BOOTSTRAP=<namespace>.servicebus.windows.net:9093

# Full Event Hubs connection string. Presence of this var flips both the
# Python detector and the Node metaverse to SASL_SSL / $ConnectionString auth.
EVENTHUBS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<rule>;SharedAccessKey=<key>

# Detector grid — must match the metaverse zone overlay (see env.dev.example).
CELL_SIZE_X=30
CELL_SIZE_Y=30
GRID_ORIGIN_X=-240
GRID_ORIGIN_Y=-195
