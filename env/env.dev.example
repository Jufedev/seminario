# ─────────────────────────────────────────────────────────────────────────
# DEVELOPMENT profile — everything runs locally inside the distrobox.
# Native Kafka (scripts/kafka-local.sh), local PySpark, metaverse via bun.
#
# Usage:  cp env/env.dev.example .env   (then `set -a; . ./.env; set +a`)
# Both the Python detector and the Node metaverse read these same variables,
# which is what keeps dev and prod in parity — same code, different endpoint.
# ─────────────────────────────────────────────────────────────────────────

# Kafka bootstrap server. Native single-node KRaft broker in the box.
KAFKA_BOOTSTRAP=localhost:9092

# Spark detector grid — MUST match the metaverse zone overlay exactly
# (metaverse/src/analytics/config.js). Cells of 30x30 world units anchored at
# (-240,-195): half a block BEFORE the map, so every cell boundary falls
# mid-block and no street axis ever straddles two cells (streets run every 30
# units). Each cell holds one intersection centered with its four half-streets.
CELL_SIZE_X=30
CELL_SIZE_Y=30
GRID_ORIGIN_X=-240
GRID_ORIGIN_Y=-195

# Detection thresholds — "live queue" calibration (validated visually 2026-07).
# The SHORT window is the key: 7+ distinct stopped avatars inside a 10 s
# window approximates 7+ SIMULTANEOUSLY stopped cars (a real queue, lights
# included), so zones turn red while the queue exists and clear ~15 s (TTL)
# after it drains. A long window counts cars that stopped and left long ago,
# which kept every busy light permanently red. Code defaults: 30s/10s, 12, 5.
# WINDOW changes alter Spark streaming state: run `make clean` before restart.
WINDOW_DURATION=10 seconds
WINDOW_SLIDE=5 seconds
MIN_MEAN_DWELL_S=5
MIN_STATIONARY_AVATARS=7
